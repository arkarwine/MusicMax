# from my.telegram.org/apps
API_ID=
API_HASH=

# from @BotFather on telegram
BOT_TOKEN=
# Use Bot API 10.2 native rich headings, with automatic HTML fallback.
RICH_MESSAGES=true

# Optional URL button shown below the /play controls.
# The button is hidden unless both values are set.
PLAY_BUTTON_TEXT=
PLAY_BUTTON_URL=


# SQLite database file (relative paths are resolved from the project directory)
DATABASE_PATH=data/anonxmusic.db

OWNER_ID=

# Initial Pyrogram session from @StringFatherBot on Telegram.
# Add every additional session at runtime with /addsession.
SESSION=
