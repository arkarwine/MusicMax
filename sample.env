# from my.telegram.org/apps
API_ID=
API_HASH=

# from @BotFather on telegram
BOT_TOKEN=
# Use Bot API 10.2 native rich headings, with automatic HTML fallback.
RICH_MESSAGES=true

# Optional URL button shown below the /play controls.
# The button is hidden unless both values are set.
PLAY_BUTTON_TEXT=
PLAY_BUTTON_URL=

# Optional first slide for /play; generated track artwork remains second.
PLAY_IMAGE=

# /play controls: commas share a row; pipes start a new row; - hides all.
# Tokens: loop, stop, pause, skip, replay. Omit any token to hide it.
PLAY_CONTROLS_LAYOUT=loop,stop,pause,skip,replay

# Safe values can also be changed with /config and persist in SQLite.
# Precedence: /config override > active theme > this environment file.
# Optional Markdown templates. Leave empty to use localized defaults.
# Placeholders: image, title, title_link, duration, requester, source_url.
PLAY_MESSAGE_TEMPLATE_EN=
PLAY_MESSAGE_TEMPLATE_MY=


# SQLite database file (relative paths are resolved from the project directory)
DATABASE_PATH=data/anonxmusic.db

OWNER_ID=

# Initial Pyrogram session from @StringFatherBot on Telegram.
# Add every additional session at runtime with /addsession.
SESSION=
